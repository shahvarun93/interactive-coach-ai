{
    "compilerOptions": {
      "target": "ES2020",
      "module": "Node16",
      "rootDir": "src",
      "outDir": "dist",
      "strict": true,
      "moduleResolution": "node16",
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "skipLibCheck": true
    },
    "exclude": ["scripts", "node_modules", "dist"]
  }