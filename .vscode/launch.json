{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug API (ts-node)",
            "skipFiles": [
                "<node_internals>/**",
                "node_modules/**"
            ],
            "runtimeArgs": [
                "-r",
                "ts-node/register"
            ],
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "program": "${workspaceFolder}/src/index.ts",
            "preLaunchTask": "tsc: build - tsconfig.json",
            "outFiles": [
                "${workspaceFolder}/dist/**/*.js"
            ]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug: npm run cli:sd",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "cli:sd"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal", // <- important for readline
            "restart": false,
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug: npm run seed:sd",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "seed:sd"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal", // <- important for readline
            "restart": false,
            "envFile": "${workspaceFolder}/.env",
            "skipFiles": ["<node_internals>/**"]
          }
    ]
}